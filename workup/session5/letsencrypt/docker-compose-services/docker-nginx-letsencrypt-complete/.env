#  This file is used to set environment variables for the Docker Compose setup. It includes configuration for Let's Encrypt, 
#  as well as virtual host settings for both the API and the web server.

ENV_LETSENCRYPT_HOST=nocinstance1.noc.dev.aws1.interfbn.com
ENV_LETSENCRYPT_EMAIL=gallen.craig@gmail.com

API_VIRTUAL_HOST=nocinstance1.noc.dev.aws1.interfbn.com
API_VIRTUAL_NETWORK=nginx-proxy
API_VIRTUAL_PORT=3000

WEB_VIRTUAL_HOST=nocinstance1.noc.dev.aws1.interfbn.com
WEB_VIRTUAL_NETWORK=nginx-proxy
WEB_VIRTUAL_PORT=80

